rules_version = '2';

// Credit balances are managed exclusively by the server (Firebase Admin SDK,
// which bypasses these rules). Clients must never read or write other users'
// data, and must never modify their own `credits`. A signed-in user may read
// their own document (to display the balance) but not write it.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // server-only via Admin SDK
    }
    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
