# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Optional model override (default: gemini-3-flash-preview).
# The server falls back to gemini-2.5-flash automatically if the model disappears.
GEMINI_MODEL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Firebase (auth + klippekort/credits) ---

# CLIENT (browser) config — NOT secret, exposed in the built frontend.
# From Firebase console > Project settings > "Your apps" (Web app).
VITE_FIREBASE_API_KEY="..."
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="..."
VITE_FIREBASE_APP_ID="..."

# SERVER (admin) credentials — SECRET. Service account JSON as a single line.
# From Firebase console > Project settings > Service accounts > Generate key.
# On Google Cloud Run you can omit this and rely on the runtime service account.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account", ...}'

# New users start with this many free credits (klipp). Default: 1.
STARTER_CREDITS="1"

# Shared secret for the manual top-up endpoint (/api/admin/grant-credits).
# Kept as an admin fallback. Pick a long random string.
ADMIN_TOPUP_SECRET="change-me-to-a-long-random-string"

# Signs interview session tokens. Pick a long random string.
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Stripe (Fase 2: selvbetjent kjøp av klipp) ---
# Begge må være satt for at kjøp skal være aktivt; ellers viser UI "kommer snart".
# Start med TEST-nøkler (sk_test_...) — virker uten verifisert foretak.
# STRIPE_SECRET_KEY: Stripe Dashboard > Developers > API keys.
STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET: fra webhook-endepunktet (whsec_...). Lokalt: stripe CLI
# `stripe listen --forward-to localhost:3000/api/stripe-webhook` gir deg en.
STRIPE_WEBHOOK_SECRET=""

# --- E-postkvittering (angrerettloven § 18) ---
# Uten disse logges kvitteringen i serverloggen (forberedt, men sender ikke e-post).
# Sett begge for å sende ekte kvittering via Resend (https://resend.com).
RESEND_API_KEY=""
EMAIL_FROM=""                              # f.eks. "Big Five <kvittering@dittdomene.no>"
SUPPORT_EMAIL=""                           # vises i kvitteringen som kontaktadresse
APP_URL=""                                 # prod-URL, brukes i kvitteringslenker (valgfritt)
